# Puerto del servidor HTTP/WebSocket
PORT=4000

# URL de conexion a PostgreSQL (la da Railway o tu Postgres local)
# Local ejemplo: postgresql://postgres:postgres@localhost:5432/chat?schema=public
DATABASE_URL=

# Secreto para firmar los JWT (usar un valor largo y aleatorio en produccion)
JWT_SECRET=cambiar-esto-por-un-secreto-largo-y-aleatorio

# Tiempo de expiracion del token
JWT_EXPIRES_IN=7d

# Origen permitido para CORS (URL del cliente React)
# Local: http://localhost:5173 | Produccion: https://tu-front.up.railway.app
# Tambien se usa para construir los links de verificacion y recuperacion
# que se envian por correo (ej. CLIENT_ORIGIN/verify-email?token=...).
CLIENT_ORIGIN=http://localhost:5173

# --- SMTP para envio de correos (verificacion de email y recuperacion) ---
# Datos de tu proveedor SMTP. Ejemplos de host: smtp.gmail.com, smtp.zoho.com.
SMTP_HOST=
# 587 con STARTTLS (SMTP_SECURE=false) o 465 con TLS directo (SMTP_SECURE=true)
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remitente que veran los usuarios en el correo
MAIL_FROM="Chat en tiempo real <no-reply@ejemplo.com>"
