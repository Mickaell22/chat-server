# Puerto del servidor HTTP/WebSocket
PORT=4000

# URL de conexion a PostgreSQL (la da Railway o tu Postgres local)
# Local ejemplo: postgresql://postgres:postgres@localhost:5432/chat?schema=public
DATABASE_URL=

# Secreto para firmar los JWT (usar un valor largo y aleatorio en produccion)
JWT_SECRET=cambiar-esto-por-un-secreto-largo-y-aleatorio

# Tiempo de expiracion del token
JWT_EXPIRES_IN=7d

# Origen permitido para CORS (URL del cliente React)
# Local: http://localhost:5173 | Produccion: https://tu-front.up.railway.app
CLIENT_ORIGIN=http://localhost:5173
